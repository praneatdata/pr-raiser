# Slack -> OAuth & Permissions -> Bot User OAuth Token
SLACK_BOT_TOKEN=xoxb-your-bot-token

# Slack -> Basic Information -> App-Level Tokens (scope: connections:write)
# Only needed for Socket Mode (app.py / Docker), not for the HTTP mode on Vercel.
SLACK_APP_TOKEN=xapp-your-app-token

# Slack -> Basic Information -> App Credentials -> Signing Secret
# Only needed for HTTP mode (api/index.py on Vercel).
SLACK_SIGNING_SECRET=your-signing-secret

# GitHub -> Settings -> Developer settings -> Personal access tokens (classic, scope: repo)
GITHUB_TOKEN=ghp_your-token
